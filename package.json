{
	"name": "slides",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@11.0.8",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "vite --host 127.0.0.1 --strictPort",
		"build": "vite build && node scripts/copy-katex-assets.mjs",
		"preview": "vite preview --host 127.0.0.1 --strictPort",
		"docs:dev": "pnpm --filter @slides/docs dev",
		"docs:build": "pnpm --filter @slides/docs build",
		"typecheck": "tsc -p tsconfig.json --noEmit && tsc -p packages/ui/tsconfig.json --noEmit && pnpm --filter @slides/docs typecheck",
		"lint": "eslint . --max-warnings=0",
		"test:ui": "vitest run --config vitest.config.ts",
		"validate": "pnpm run typecheck && pnpm run lint && pnpm run test:ui && pnpm run validate:plugin-presets && pnpm run validate:slides && pnpm run docs:build && pnpm run test:e2e && pnpm run test:e2e:preview",
		"validate:bundle": "node scripts/validate-default-bundle.mjs",
		"validate:plugin-presets": "vite build --config vite.plugin-presets.config.ts",
		"validate:rendered-deck": "node scripts/validate-rendered-deck.mjs",
		"validate:slides": "pnpm run build && pnpm run validate:rendered-deck && pnpm run validate:bundle",
		"test:e2e": "playwright test",
		"test:e2e:preview": "pnpm run build && PLAYWRIGHT_BASE_URL=http://127.0.0.1:4173 PLAYWRIGHT_WEB_SERVER_COMMAND=\"pnpm preview\" playwright test",
		"export:pdf": "decktape reveal http://127.0.0.1:4173 slides.pdf"
	},
	"dependencies": {
		"@revealjs/react": "0.2.1",
		"@workspace/ui": "workspace:*",
		"katex": "0.16.45",
		"react": "19.2.6",
		"react-dom": "19.2.6",
		"reveal.js": "6.0.1",
		"reveal.js-appearance": "1.4.0",
		"reveal.js-copycode": "1.4.2",
		"reveal.js-mermaid-plugin": "11.12.3",
		"reveal.js-simplemenu": "2.0.3",
		"reveal.js-verticator": "1.3.2"
	},
	"devDependencies": {
		"@axe-core/playwright": "4.11.3",
		"@eslint/js": "9.39.1",
		"@playwright/test": "1.59.1",
		"@tailwindcss/vite": "4.3.0",
		"@testing-library/react": "16.3.2",
		"@types/node": "24.10.1",
		"@types/react": "19.2.7",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "6.0.1",
		"decktape": "3.16.1",
		"eslint": "9.39.1",
		"eslint-plugin-react-hooks": "7.0.1",
		"eslint-plugin-react-refresh": "0.4.24",
		"globals": "16.5.0",
		"jsdom": "29.1.1",
		"revealjs-validator": "0.16.1",
		"tailwindcss": "4.3.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.47.0",
		"vite": "8.0.11",
		"vitest": "4.1.6"
	}
}
